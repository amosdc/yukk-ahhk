<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>AquaInnovate Jakarta — SOFTCOMPT 2026</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<style>
/* ═══════════════════════════════════════
   DESIGN TOKENS
   ═══════════════════════════════════════ */
:root{
  --bg:          #EDF7F9;
  --bg-alt:      #F8FEFF;
  --bg-hero:     #E0F1F6;
  --surface:     rgba(255,255,255,0.75);
  --surface-2:   rgba(255,255,255,0.93);
  --border:      rgba(0,180,170,0.18);
  --border-soft: rgba(0,0,0,0.07);

  --teal:        #009B92;
  --teal-light:  #00D4C8;
  --teal-dim:    rgba(0,155,146,0.10);
  --teal-mid:    rgba(0,155,146,0.22);
  --teal-glow:   rgba(0,155,146,0.40);
  --cyan:        #0EA5E9;
  --cyan-dim:    rgba(14,165,233,0.10);
  --danger:      #E53935;
  --danger-dim:  rgba(229,57,53,0.09);
  --amber:       #F59E0B;
  --amber-dim:   rgba(245,158,11,0.10);
  --emerald:     #059669;
  --emerald-dim: rgba(5,150,105,0.09);

  --ink:         #0A2530;
  --ink-2:       #1A404E;
  --body:        #324B55;
  --muted:       #5E8090;
  --faint:       #A0BECA;

  --shadow-sm:   0 1px 4px rgba(0,0,0,0.06),0 1px 2px rgba(0,0,0,0.04);
  --shadow-md:   0 4px 20px rgba(0,0,0,0.08),0 2px 6px rgba(0,0,0,0.04);
  --shadow-lg:   0 12px 48px rgba(0,0,0,0.10),0 4px 14px rgba(0,0,0,0.06);
  --shadow-teal: 0 4px 28px rgba(0,155,146,0.28);
  --shadow-teal-lg: 0 8px 48px rgba(0,155,146,0.35);
}

/* ── Reset ── */
*{box-sizing:border-box;margin:0;padding:0;}
html{background:var(--bg);scroll-behavior:smooth;}
body{
  font-family:'DM Sans',sans-serif;
  background:var(--bg);color:var(--body);
  overflow-x:hidden;
}
.mono{font-family:'Space Mono',monospace;}
.syne{font-family:'Syne',sans-serif;}

/* ═══════════════════════════════════════
   LOADING SCREEN ANIMATION
   ═══════════════════════════════════════ */
#loader{
  position:fixed;inset:0;z-index:9999;
  background:var(--bg-hero);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem;
  transition:opacity 0.6s ease, visibility 0.6s;
}
#loader.hide{opacity:0;visibility:hidden;pointer-events:none;}
.loader-logo{
  display:flex;align-items:center;gap:0.75rem;
  animation:loaderFadeIn 0.6s ease both;
}
.loader-logo span{
  font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;
  color:var(--ink);
}
.loader-logo span em{color:var(--teal);font-style:normal;}
.loader-bar-wrap{
  width:200px;height:3px;background:rgba(0,155,146,0.15);border-radius:2px;overflow:hidden;
  animation:loaderFadeIn 0.6s 0.2s ease both;
}
.loader-bar{
  height:100%;background:linear-gradient(to right,var(--teal),var(--teal-light));
  border-radius:2px;width:0%;
  animation:loaderFill 1.6s cubic-bezier(0.4,0,0.2,1) 0.3s both;
}
.loader-text{
  font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.2em;
  text-transform:uppercase;color:var(--muted);
  animation:loaderFadeIn 0.6s 0.3s ease both;
}
@keyframes loaderFadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
@keyframes loaderFill{0%{width:0%}60%{width:75%}100%{width:100%}}

/* Water drop loader icon */
.loader-drop{
  width:52px;height:52px;position:relative;
  animation:loaderDropBounce 1.8s ease-in-out infinite;
}
.loader-drop svg{width:100%;height:100%;}
@keyframes loaderDropBounce{
  0%,100%{transform:translateY(0) scale(1);}
  50%{transform:translateY(-12px) scale(1.05);}
}

/* ── Background noise ── */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
  opacity:0.5;
}

/* ── Animated background particles ── */
.bg-particles{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;}
.particle{
  position:absolute;border-radius:50%;
  background:var(--teal);opacity:0;
  animation:particleFloat var(--dur,8s) var(--delay,0s) ease-in-out infinite;
}
@keyframes particleFloat{
  0%{opacity:0;transform:translateY(100vh) scale(0);}
  10%{opacity:var(--op,0.06);}
  90%{opacity:var(--op,0.06);}
  100%{opacity:0;transform:translateY(-20vh) scale(1) rotate(180deg);}
}

/* ── Ambient orbs ── */
.orb{position:fixed;border-radius:50%;filter:blur(140px);pointer-events:none;z-index:0;}
.orb-1{width:700px;height:700px;background:radial-gradient(circle,rgba(0,212,200,0.12),transparent 65%);top:-200px;right:-180px;animation:orbDrift1 18s ease-in-out infinite;}
.orb-2{width:550px;height:550px;background:radial-gradient(circle,rgba(14,165,233,0.09),transparent 65%);bottom:-100px;left:-180px;animation:orbDrift2 22s ease-in-out infinite;}
.orb-3{width:450px;height:450px;background:radial-gradient(circle,rgba(0,155,146,0.07),transparent 65%);top:45%;left:32%;animation:orbDrift3 15s ease-in-out infinite;}
@keyframes orbDrift1{0%,100%{transform:translate(0,0)}33%{transform:translate(-30px,20px)}66%{transform:translate(20px,-15px)}}
@keyframes orbDrift2{0%,100%{transform:translate(0,0)}33%{transform:translate(20px,-25px)}66%{transform:translate(-15px,15px)}}
@keyframes orbDrift3{0%,100%{transform:translate(0,0)}50%{transform:translate(25px,20px)}}

/* ── Hero grid ── */
.hero-grid{
  background-image:
    linear-gradient(rgba(0,155,146,0.05) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,155,146,0.05) 1px,transparent 1px);
  background-size:48px 48px;
}

/* ═══════════════════════════════════════
   GLASS
   ═══════════════════════════════════════ */
.glass{
  background:var(--surface);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:1px solid var(--border-soft);border-radius:20px;box-shadow:var(--shadow-sm);
}
.glass-card{
  background:var(--surface-2);
  backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
  border:1px solid var(--border-soft);border-radius:24px;box-shadow:var(--shadow-md);
}

/* ═══════════════════════════════════════
   NAVBAR
   ═══════════════════════════════════════ */
.nav-light{
  background:rgba(237,247,249,0.90);
  backdrop-filter:blur(30px);-webkit-backdrop-filter:blur(30px);
  border-bottom:1px solid rgba(0,155,146,0.10);
  transition:box-shadow 0.3s;
}
.nav-light.scrolled{box-shadow:0 2px 20px rgba(0,0,0,0.08);}
.nav-link{
  position:relative;color:var(--muted);font-size:0.875rem;font-weight:500;
  transition:color 0.25s;letter-spacing:-0.01em;
}
.nav-link::after{
  content:'';position:absolute;bottom:-4px;left:0;right:100%;height:2px;
  background:linear-gradient(to right,var(--teal),var(--teal-light));
  border-radius:2px;transition:right 0.35s cubic-bezier(0.4,0,0.2,1);
}
.nav-link:hover,.nav-link.active{color:var(--teal);}
.nav-link:hover::after,.nav-link.active::after{right:0;}

/* ═══════════════════════════════════════
   TYPOGRAPHY
   ═══════════════════════════════════════ */
.hero-title{
  font-family:'Syne',sans-serif;
  font-size:clamp(2.4rem,5.5vw,4.8rem);
  font-weight:800;line-height:1.02;letter-spacing:-0.035em;
  color:var(--ink);
}
.hero-title .accent{
  background:linear-gradient(135deg,var(--teal) 0%,var(--teal-light) 55%,var(--cyan) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.section-title{
  font-family:'Syne',sans-serif;font-weight:800;
  letter-spacing:-0.03em;line-height:1.05;color:var(--ink);
}
.sub-headline{
  font-family:'DM Sans',sans-serif;font-weight:400;
  color:var(--muted);line-height:1.7;font-size:1rem;
}
.kicker{
  font-family:'DM Sans',sans-serif;font-size:0.7rem;font-weight:700;
  text-transform:uppercase;letter-spacing:0.16em;color:var(--teal);
}
.data-label{
  font-family:'Space Mono',monospace;font-size:0.65rem;font-weight:700;
  text-transform:uppercase;letter-spacing:0.14em;color:var(--muted);
}

/* ═══════════════════════════════════════
   BADGE
   ═══════════════════════════════════════ */
.badge{
  display:inline-flex;align-items:center;gap:0.45rem;
  background:var(--teal-dim);border:1px solid var(--teal-mid);color:var(--teal);
  font-family:'DM Sans',sans-serif;font-size:0.67rem;font-weight:700;
  letter-spacing:0.14em;text-transform:uppercase;
  padding:0.38rem 1rem;border-radius:999px;
}
.badge-dot{width:5px;height:5px;border-radius:50%;background:currentColor;animation:badgePulse 2s ease-in-out infinite;}
@keyframes badgePulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.8)}}

/* ═══════════════════════════════════════
   BUTTONS
   ═══════════════════════════════════════ */
.btn-primary{
  font-family:'Syne',sans-serif;font-weight:700;font-size:0.9rem;
  padding:0.8rem 1.75rem;border-radius:999px;display:inline-block;
  background:var(--teal);color:white;box-shadow:var(--shadow-teal);
  position:relative;overflow:hidden;
  transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.25s;
}
.btn-primary::before{
  content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.22),transparent);
  transition:left 0.5s ease;
}
.btn-primary:hover{transform:translateY(-3px) scale(1.02);box-shadow:var(--shadow-teal-lg);}
.btn-primary:hover::before{left:100%;}
.btn-primary:active{transform:translateY(-1px);}

.btn-secondary{
  font-family:'Syne',sans-serif;font-weight:700;font-size:0.9rem;
  padding:0.8rem 1.75rem;border-radius:999px;display:inline-block;
  background:white;color:var(--teal);border:1.5px solid var(--teal-mid);
  box-shadow:var(--shadow-sm);
  transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1),border-color 0.2s,box-shadow 0.2s;
}
.btn-secondary:hover{transform:translateY(-3px);border-color:var(--teal);box-shadow:var(--shadow-teal);}

/* ═══════════════════════════════════════
   METRIC PILL
   ═══════════════════════════════════════ */
.metric-pill{
  background:white;border:1px solid var(--border);border-radius:999px;
  padding:0.5rem 1.25rem;box-shadow:var(--shadow-sm);display:inline-block;
  transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.3s;
}
.metric-pill:hover{transform:translateY(-3px) scale(1.04);box-shadow:var(--shadow-teal);}
.metric-pill .num{
  font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;
  background:linear-gradient(135deg,var(--teal),var(--cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}

/* ═══════════════════════════════════════
   SECTION DIVIDER
   ═══════════════════════════════════════ */
.section-divider{
  height:1px;max-width:55%;margin:0 auto;
  background:linear-gradient(to right,transparent,rgba(0,155,146,0.2),transparent);
}

/* ═══════════════════════════════════════
   SCROLL REVEAL
   ═══════════════════════════════════════ */
.sr{opacity:0;transform:translateY(40px);transition:opacity 0.8s ease,transform 0.8s ease;}
.sr.in{opacity:1;transform:none;}
.sr-l{opacity:0;transform:translateX(-40px);transition:opacity 0.8s ease,transform 0.8s ease;}
.sr-l.in{opacity:1;transform:none;}
.sr-r{opacity:0;transform:translateX(40px);transition:opacity 0.8s ease,transform 0.8s ease;}
.sr-r.in{opacity:1;transform:none;}
.sr-scale{opacity:0;transform:scale(0.9);transition:opacity 0.8s ease,transform 0.8s ease;}
.sr-scale.in{opacity:1;transform:scale(1);}

/* ═══════════════════════════════════════
   HERO ENTRANCE ANIMATIONS
   ═══════════════════════════════════════ */
@keyframes heroA{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:none}}
@keyframes heroB{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:none}}
@keyframes heroC{from{opacity:0;transform:translateY(50px)}to{opacity:1;transform:none}}
@keyframes heroGlobe{from{opacity:0;transform:translateX(60px) scale(0.88)}to{opacity:1;transform:none}}
@keyframes statStrip{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:none}}

.hero-badge{animation:heroA 0.9s 0.2s ease both;}
.hero-title-wrap{animation:heroB 0.9s 0.35s ease both;}
.hero-sub{animation:heroC 0.9s 0.5s ease both;}
.hero-bullets{animation:heroC 0.9s 0.6s ease both;}
.hero-cta{animation:heroC 0.9s 0.75s ease both;}
.hero-globe-wrap{animation:heroGlobe 1.1s 0.4s ease both;}
.hero-stats{animation:statStrip 0.9s 0.9s ease both;}

/* ═══════════════════════════════════════
   GLOBE 3D EFFECT
   ═══════════════════════════════════════ */
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-16px)}}
@keyframes spinSlow{to{transform:rotate(360deg)}}
@keyframes spinSlowReverse{to{transform:rotate(-360deg)}}
@keyframes pulseRing{0%,100%{opacity:0.7;transform:scale(1)}50%{opacity:0.3;transform:scale(1.1)}}
@keyframes waveFlow{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

.globe-float{animation:floatY 7s ease-in-out infinite;}
.spin-slow{animation:spinSlow 26s linear infinite;}
.spin-slow-rev{animation:spinSlowReverse 20s linear infinite;}
.wave-continuous{animation:waveFlow 3.5s linear infinite;}
.pulse-ring{animation:pulseRing 3s ease-in-out infinite;}

/* Globe 3D tilt on hover */
.globe-container{
  perspective:800px;
  transition:transform 0.1s ease;
}
.globe-inner{
  transform-style:preserve-3d;
  transition:transform 0.3s ease;
}

/* ═══════════════════════════════════════
   HERO BULLETS
   ═══════════════════════════════════════ */
.hero-bullet{
  display:flex;align-items:center;gap:0.9rem;padding:0.5rem 0;
  transition:transform 0.3s ease;
}
.hero-bullet:hover{transform:translateX(6px);}
.bullet-icon{
  width:2.2rem;height:2.2rem;border-radius:10px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
.hero-bullet:hover .bullet-icon{transform:scale(1.18) rotate(8deg);}

/* ═══════════════════════════════════════
   TIMELINE — ENHANCED
   ═══════════════════════════════════════ */
.timeline-track{
  position:absolute;left:1.6rem;top:6px;bottom:6px;width:2px;border-radius:2px;
  background:linear-gradient(to bottom,var(--danger) 0%,var(--amber) 40%,#FB923C 70%,var(--cyan) 100%);
  overflow:hidden;
}
.timeline-track::after{
  content:'';position:absolute;left:0;right:0;height:50%;
  background:linear-gradient(to bottom,transparent,rgba(255,255,255,0.85),transparent);
  animation:trackSweep 2.8s linear infinite;
}
@keyframes trackSweep{0%{top:-50%}100%{top:150%}}

.tl-item{position:relative;transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1);}
.tl-item:hover{transform:translateX(8px);}

.tl-dot{
  width:2.6rem;height:2.6rem;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  position:relative;z-index:2;
  transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.3s;
}
.tl-item:hover .tl-dot{transform:scale(1.22) rotate(10deg);}

.tl-card{
  background:var(--surface-2);
  border:1.5px solid var(--border-soft);border-radius:20px;
  box-shadow:var(--shadow-md);overflow:hidden;position:relative;
  transition:box-shadow 0.35s,border-color 0.35s,transform 0.35s ease;
}
.tl-card::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;
  background:var(--accent-color,var(--teal));
  transform:scaleY(0);transform-origin:top;
  transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
}
.tl-item:hover .tl-card{box-shadow:var(--shadow-lg);transform:translateY(-2px);}
.tl-item:hover .tl-card::before{transform:scaleY(1);}

/* ═══════════════════════════════════════
   SOLUTION CARDS — 3D HOVER
   ═══════════════════════════════════════ */
.sol-card{
  background:var(--surface-2);border:1.5px solid var(--border-soft);
  border-radius:24px;box-shadow:var(--shadow-md);
  position:relative;overflow:hidden;
  transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1),
             box-shadow 0.4s,border-color 0.3s;
  transform-style:preserve-3d;
  perspective:600px;
}
.sol-card::after{
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at var(--mx,50%) var(--my,50%),
    rgba(0,155,146,0.14) 0%,transparent 65%);
  opacity:0;transition:opacity 0.3s;pointer-events:none;
}
.sol-card:hover{
  transform:translateY(-10px) rotateX(4deg);
  box-shadow:var(--shadow-teal-lg);border-color:var(--teal-mid);
}
.sol-card:hover::after{opacity:1;}

.sol-icon{
  width:4.5rem;height:4.5rem;border-radius:1.25rem;
  display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
  transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
}
.sol-card:hover .sol-icon{transform:scale(1.12) rotate(-6deg);}

/* Scan line */
.scan-wrap{position:relative;overflow:hidden;}
.scan-wrap::after{
  content:'';position:absolute;left:0;right:0;height:2px;pointer-events:none;
  background:linear-gradient(to right,transparent,var(--teal),transparent);
  animation:scanline 3.5s linear infinite;opacity:0.18;
}
@keyframes scanline{0%{top:-5%}100%{top:105%}}

/* ═══════════════════════════════════════
   CALCULATOR
   ═══════════════════════════════════════ */
.calc-wrap{
  background:linear-gradient(160deg,rgba(0,155,146,0.04),rgba(14,165,233,0.03) 50%,rgba(0,155,146,0.04));
  border:1.5px solid var(--teal-mid);border-radius:28px;
  box-shadow:var(--shadow-lg),0 0 80px rgba(0,155,146,0.07);
  overflow:hidden;
}

input[type=range].fancy-slider{
  -webkit-appearance:none;appearance:none;
  width:100%;height:6px;border-radius:999px;outline:none;cursor:pointer;
  background:linear-gradient(to right,var(--teal) var(--pct,0%),rgba(0,155,146,0.15) var(--pct,0%));
  transition:background 0.05s;
}
input[type=range].fancy-slider::-webkit-slider-thumb{
  -webkit-appearance:none;width:28px;height:28px;border-radius:50%;
  background:white;border:3px solid var(--teal);cursor:pointer;
  box-shadow:0 2px 14px rgba(0,155,146,0.45),0 0 0 0 rgba(0,155,146,0.25);
  transition:transform 0.25s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.25s;
}
input[type=range].fancy-slider::-webkit-slider-thumb:hover{
  transform:scale(1.3);
  box-shadow:0 2px 20px rgba(0,155,146,0.55),0 0 0 10px rgba(0,155,146,0.12);
}
input[type=range].fancy-slider:active::-webkit-slider-thumb{
  transform:scale(1.15);
  box-shadow:0 2px 24px rgba(0,155,146,0.55),0 0 0 16px rgba(0,155,146,0.10);
}

.result-card{
  background:white;border:1.5px solid transparent;border-radius:20px;
  padding:1.4rem 1.6rem;position:relative;overflow:hidden;
  box-shadow:var(--shadow-sm);
  transition:border-color 0.35s,box-shadow 0.35s,transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
}
.result-card::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 0% 0%,var(--card-glow,var(--teal-dim)),transparent 65%);
  pointer-events:none;
}
.result-card:hover{border-color:var(--teal-mid);box-shadow:var(--shadow-teal);transform:translateY(-5px);}
.result-num{
  font-family:'Syne',sans-serif;font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:800;
  transition:transform 0.2s ease;
}

@keyframes ripplePop{
  0%{transform:scale(1)}40%{transform:scale(1.1)}70%{transform:scale(0.96)}100%{transform:scale(1)}
}
.ripple{animation:ripplePop 0.4s cubic-bezier(0.34,1.56,0.64,1);}

/* Gauge */
.gauge-ring{position:relative;width:130px;height:130px;flex-shrink:0;}
.gauge-ring svg{transform:rotate(-90deg);}
.gauge-track{fill:none;stroke:rgba(0,155,146,0.12);stroke-width:9;}
.gauge-fill{
  fill:none;stroke-width:9;stroke-linecap:round;stroke:url(#gaugeGrad);
  stroke-dasharray:380;stroke-dashoffset:380;
  transition:stroke-dashoffset 0.7s cubic-bezier(0.4,0,0.2,1);
}
.gauge-label{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.gauge-pct{
  font-family:'Syne',sans-serif;font-size:1.55rem;font-weight:800;
  background:linear-gradient(135deg,var(--teal),var(--cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}

/* Slider ticks */
.slider-ticks{display:flex;justify-content:space-between;padding:0 14px;margin-top:6px;}
.slider-tick{width:1px;height:5px;background:rgba(0,155,146,0.2);border-radius:1px;position:relative;}
.stl{position:absolute;top:9px;left:50%;transform:translateX(-50%);font-size:0.58rem;color:var(--faint);white-space:nowrap;font-family:'Space Mono',monospace;}

/* Water viz */
.water-vis{position:relative;height:52px;overflow:hidden;border-radius:12px;background:linear-gradient(to bottom,rgba(14,165,233,0.05),rgba(0,155,146,0.08));margin-top:0.75rem;}

/* ═══════════════════════════════════════
   ECONOMICS
   ═══════════════════════════════════════ */
.econ-card{
  border-radius:24px;overflow:hidden;box-shadow:var(--shadow-md);
  transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.35s;
}
.econ-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg);}
.econ-row{
  display:flex;gap:0.875rem;padding:0.875rem 0;
  border-bottom:1px solid rgba(0,0,0,0.05);
  transition:padding-left 0.25s;padding-left:0.5rem;border-radius:8px;
}
.econ-row:last-of-type{border-bottom:none;}
.econ-card:hover .econ-row{padding-left:0.875rem;}

/* Mobile econ tabs */
.econ-tab-bar{display:none;}
@media(max-width:767px){
  .econ-tab-bar{display:flex;border-radius:14px;overflow:hidden;border:1px solid rgba(0,0,0,0.08);margin-bottom:1rem;}
  .econ-tab{flex:1;padding:0.65rem 1rem;text-align:center;font-size:0.8rem;font-weight:600;cursor:pointer;transition:background 0.2s,color 0.2s;background:white;color:var(--muted);font-family:'Syne',sans-serif;}
  .econ-tab.active-d{background:var(--danger);color:white;}
  .econ-tab.active-t{background:var(--teal);color:white;}
  .econ-split{grid-template-columns:1fr!important;}
}
.econ-split{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}

/* ═══════════════════════════════════════
   MAP
   ═══════════════════════════════════════ */
.map-zone{cursor:pointer;transition:opacity 0.2s,filter 0.2s,transform 0.2s;}
.map-zone:hover{opacity:0.8;filter:brightness(0.93) saturate(1.3);}
.map-tooltip{
  position:absolute;pointer-events:none;background:white;
  border:1px solid rgba(0,0,0,0.08);border-radius:16px;padding:1rem 1.2rem;
  box-shadow:0 12px 40px rgba(0,0,0,0.15);min-width:185px;z-index:50;
  opacity:0;transform:translateY(8px) scale(0.96);
  transition:opacity 0.22s,transform 0.22s;
}
.map-tooltip.show{opacity:1;transform:translateY(0) scale(1);}
.risk-bar{height:5px;border-radius:3px;margin-top:8px;transition:width 0.5s ease;}

/* ═══════════════════════════════════════
   MYTH CARDS
   ═══════════════════════════════════════ */
.myth-wrap{
  background:var(--surface-2);border:1px solid var(--border-soft);
  border-radius:20px;overflow:hidden;box-shadow:var(--shadow-sm);
  transition:box-shadow 0.35s,transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
}
.myth-wrap:hover{box-shadow:var(--shadow-md);transform:translateY(-3px);}
.myth-h{padding:0.85rem 1.4rem;font-size:0.7rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;font-family:'Space Mono',monospace;}
.myth-b{padding:1.1rem 1.4rem;}

/* ═══════════════════════════════════════
   ABOUT CARDS — 3D hover
   ═══════════════════════════════════════ */
.about-card{
  background:var(--surface-2);border:1px solid var(--border-soft);
  border-radius:24px;box-shadow:var(--shadow-md);padding:2rem;
  transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.4s,border-color 0.3s;
  perspective:600px;transform-style:preserve-3d;
}
.about-card:hover{
  transform:translateY(-8px) rotateY(-4deg);
  box-shadow:var(--shadow-teal-lg);border-color:var(--teal-mid);
}
.about-icon{
  width:3.5rem;height:3.5rem;border-radius:1rem;
  display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;
  transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
}
.about-card:hover .about-icon{transform:scale(1.15) rotate(-8deg);}

/* ═══════════════════════════════════════
   CONTACT FORM
   ═══════════════════════════════════════ */
.form-input{
  width:100%;background:white;border:1.5px solid rgba(0,0,0,0.09);
  border-radius:14px;padding:0.8rem 1.1rem;color:var(--ink);
  font-family:'DM Sans',sans-serif;font-size:0.9rem;
  outline:none;transition:border-color 0.25s,box-shadow 0.25s,transform 0.2s;
  box-shadow:inset 0 1px 3px rgba(0,0,0,0.04);
}
.form-input:focus{
  border-color:var(--teal);box-shadow:0 0 0 3px var(--teal-dim);
  transform:translateY(-1px);
}
.form-input::placeholder{color:var(--faint);}

/* ═══════════════════════════════════════
   MOBILE MENU
   ═══════════════════════════════════════ */
#mmenu{max-height:0;overflow:hidden;transition:max-height 0.4s ease;}
#mmenu.open{max-height:460px;}

/* ═══════════════════════════════════════
   PROGRESS BAR
   ═══════════════════════════════════════ */
.prog-bar{
  height:7px;border-radius:999px;
  background:linear-gradient(to right,var(--teal),var(--cyan));
  position:relative;overflow:hidden;
  transition:width 0.6s cubic-bezier(0.4,0,0.2,1);
}
.prog-bar::after{
  content:'';position:absolute;top:0;bottom:0;width:60px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.55),transparent);
  animation:shimmerBar 2.2s ease-in-out infinite;
}
@keyframes shimmerBar{0%{left:-80px}100%{left:100%}}

/* ═══════════════════════════════════════
   SCROLL INDICATOR
   ═══════════════════════════════════════ */
.scroll-ind{
  display:flex;flex-direction:column;align-items:center;gap:5px;
  opacity:0.55;
}
.scroll-ind-line{
  width:1.5px;height:32px;background:var(--teal);border-radius:1px;
  animation:scrollPulse 2.2s ease-in-out infinite;
}
@keyframes scrollPulse{0%,100%{transform:scaleY(1);opacity:0.5}50%{transform:scaleY(0.45);opacity:1}}
.scroll-ind-bounce{animation:floatY 2.5s ease-in-out infinite;}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}

/* ═══════════════════════════════════════
   CURSOR
   ═══════════════════════════════════════ */
.cur-dot{
  position:fixed;pointer-events:none;z-index:9999;
  width:8px;height:8px;border-radius:50%;background:var(--teal);
  transform:translate(-50%,-50%);mix-blend-mode:multiply;
  transition:opacity 0.3s;
}
.cur-ring{
  position:fixed;pointer-events:none;z-index:9998;
  width:34px;height:34px;border-radius:50%;
  border:1.5px solid rgba(0,155,146,0.42);
  transform:translate(-50%,-50%);
  transition:width 0.3s,height 0.3s,border-color 0.3s;
}

/* ═══════════════════════════════════════
   SOIL / WATER VISUALIZER
   ═══════════════════════════════════════ */
.soil-pattern{
  background-color:#78350F;
  background-image:linear-gradient(30deg,#451a03 12%,transparent 12.5%,transparent 87%,#451a03 87.5%),linear-gradient(150deg,#451a03 12%,transparent 12.5%,transparent 87%,#451a03 87.5%),linear-gradient(60deg,#451a03 25%,transparent 25.5%,transparent 75%,#451a03 75.5%);
  background-size:20px 35px;
}
.water-layer{background:linear-gradient(to bottom,#0EA5E9,#0369A1);transition:height 0.9s ease;}
#land-group{transition:transform 0.9s cubic-bezier(0.4,0,0.2,1);}

/* Tech badge hover */
.tech-badge{
  transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.3s;
