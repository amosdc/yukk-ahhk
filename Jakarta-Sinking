/* ── MAP ── */
(function(){
  const zones=document.querySelectorAll('.map-zone');
  const tooltip=document.getElementById('map-tooltip');
  const mapEl=document.getElementById('jakarta-map');
  const rC={Kritis:'#E53935',Tinggi:'#F59E0B',Moderat:'#059669',Rendah:'#34D399'};
  const rB={Kritis:'rgba(229,57,53,0.1)',Tinggi:'rgba(245,158,11,0.1)',Moderat:'rgba(5,150,105,0.1)',Rendah:'rgba(52,211,153,0.1)'};

  zones.forEach(z=>{
    z.addEventListener('mouseenter',e=>{
      const d=z.dataset;
      document.getElementById('tt-name').textContent=d.name;
      document.getElementById('tt-rate').textContent='−'+d.rate+' cm/yr';
      const rEl=document.getElementById('tt-risk');
      rEl.textContent=d.risk;rEl.style.background=rB[d.risk];rEl.style.color=rC[d.risk];
      const bar=document.getElementById('tt-bar');
      bar.style.background=rC[d.risk];bar.style.width=Math.min((+d.rate/25)*100,100)+'%';
      document.getElementById('tt-action').textContent=d.action;
      const rect=mapEl.getBoundingClientRect(),zR=z.getBoundingClientRect();
      tooltip.style.left=Math.max(0,zR.left-rect.left+zR.width/2-90)+'px';
      tooltip.style.top=(zR.top-rect.top+zR.height+8)+'px';
      tooltip.classList.add('show');
    });
    z.addEventListener('mouseleave',()=>tooltip.classList.remove('show'));
    z.addEventListener('click',()=>{
      const d=z.dataset;
      document.getElementById('info-placeholder').classList.add('hidden');
      document.getElementById('info-detail').classList.remove('hidden');
      document.getElementById('info-name').textContent=d.name;
      const rE=document.getElementById('info-rate');
      rE.textContent='−'+d.rate;rE.style.color=rC[d.risk];
      const rL=document.getElementById('info-risk');
      rL.textContent=d.risk.toUpperCase();rL.style.color=rC[d.risk];
      document.getElementById('info-action').textContent=d.action;
    });
  });
})();

