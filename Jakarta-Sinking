<!-- ══════════════════════════════════════
     SCRIPTS
     ══════════════════════════════════════ -->
<script>
/* ── LOADING SCREEN ── */
window.addEventListener('load',()=>{
  setTimeout(()=>{
    document.getElementById('loader').classList.add('hide');
  },2000);
});

/* ── BACKGROUND PARTICLES ── */
(function(){
  const container=document.getElementById('particles');
  const count=18;
  for(let i=0;i<count;i++){
    const p=document.createElement('div');
    p.className='particle';
    const size=Math.random()*6+3;
    p.style.cssText=`
      width:${size}px;height:${size}px;
      left:${Math.random()*100}%;
      --dur:${Math.random()*8+6}s;
      --delay:${Math.random()*8}s;
      --op:${Math.random()*0.07+0.03};
    `;
    container.appendChild(p);
  }
})();

/* ── CURSOR ── */
const curDot=document.getElementById('cur-dot');
const curRing=document.getElementById('cur-ring');
let mx=0,my=0,rx=0,ry=0;
const isMob=window.matchMedia('(hover:none)').matches;
if(!isMob){
  document.addEventListener('mousemove',e=>{
    mx=e.clientX;my=e.clientY;
    curDot.style.left=mx+'px';curDot.style.top=my+'px';
  });
  (function animR(){
    rx+=(mx-rx)*0.13;ry+=(my-ry)*0.13;
    curRing.style.left=rx+'px';curRing.style.top=ry+'px';
    requestAnimationFrame(animR);
  })();
  document.addEventListener('mousedown',()=>{curRing.style.transform='translate(-50%,-50%) scale(0.55)';curRing.style.borderColor='rgba(0,155,146,0.85)';});
  document.addEventListener('mouseup',()=>{curRing.style.transform='translate(-50%,-50%) scale(1)';curRing.style.borderColor='rgba(0,155,146,0.42)';});
  document.querySelectorAll('a,button,input,select,textarea,.metric-pill,.tech-badge,.myth-wrap,.about-card,.sol-card,.tl-item,.result-card,.econ-card').forEach(el=>{
    el.addEventListener('mouseenter',()=>{curRing.style.width='50px';curRing.style.height='50px';curRing.style.borderColor='rgba(0,155,146,0.65)';});
    el.addEventListener('mouseleave',()=>{curRing.style.width='34px';curRing.style.height='34px';curRing.style.borderColor='rgba(0,155,146,0.42)';});
  });
} else {
  curDot.style.display='none';curRing.style.display='none';
}

/* ── BURGER ── */
const burger=document.getElementById('burger');
const mmenu=document.getElementById('mmenu');
const icO=document.getElementById('ic-open');
const icC=document.getElementById('ic-close');
burger.addEventListener('click',()=>{
  mmenu.classList.toggle('open');
  icO.classList.toggle('hidden');icC.classList.toggle('hidden');
});
document.querySelectorAll('.ml').forEach(a=>{
  a.addEventListener('click',()=>{
    mmenu.classList.remove('open');
    icO.classList.remove('hidden');icC.classList.add('hidden');
  });
});

/* ── NAVBAR SCROLL SHADOW & ACTIVE ── */
const navbar=document.getElementById('navbar');
window.addEventListener('scroll',()=>{
  navbar.classList.toggle('scrolled',window.scrollY>30);
  // Parallax orbs
  const y=window.scrollY;
  document.querySelector('.orb-1').style.transform=`translateY(${y*0.07}px)`;
  document.querySelector('.orb-2').style.transform=`translateY(${-y*0.05}px)`;
});

/* ── SCROLL REVEAL ── */
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in');});
},{threshold:0.08});
document.querySelectorAll('.sr,.sr-l,.sr-r,.sr-scale').forEach(el=>obs.observe(el));

/* ── NAV ACTIVE ── */
const sections=document.querySelectorAll('section[id]');
const navLinks=document.querySelectorAll('.nav-link');
const navObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      navLinks.forEach(l=>{
        const active=l.getAttribute('href')==='#'+e.target.id;
        l.classList.toggle('active',active);
        l.style.color=active?'var(--teal)':'';
      });
    }
  });
},{threshold:0.45});
sections.forEach(s=>navObs.observe(s));

/* ── GLOBE 3D TILT ── */
const gc=document.getElementById('globeContainer');
if(gc){
  gc.addEventListener('mousemove',e=>{
    const r=gc.getBoundingClientRect();
    const cx=r.left+r.width/2,cy=r.top+r.height/2;
    const dx=(e.clientX-cx)/r.width*22;
    const dy=(e.clientY-cy)/r.height*22;
    gc.querySelector('.globe-inner').style.transform=`rotateY(${dx}deg) rotateX(${-dy}deg)`;
  });
  gc.addEventListener('mouseleave',()=>{
    gc.querySelector('.globe-inner').style.transform='';
  });
}

/* ── SOLUTION CARD GLOW ── */
function sGlow(e,el){
  const r=el.getBoundingClientRect();
  el.style.setProperty('--mx',((e.clientX-r.left)/r.width*100).toFixed(1)+'%');
  el.style.setProperty('--my',((e.clientY-r.top)/r.height*100).toFixed(1)+'%');
}

/* ── FLOW ARROWS ANIMATE ON SCROLL ── */
const arrowObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.querySelectorAll('.sol-arrow line,.sol-arrow path').forEach(el=>{
        el.style.animation='none';void el.offsetWidth;
        el.style.animation='drawArrow 1.2s ease forwards';
        el.style.strokeDasharray='36';el.style.strokeDashoffset='36';
      });
    }
  });
},{threshold:0.25});
document.querySelectorAll('#solution-flow').forEach(s=>arrowObs.observe(s));

