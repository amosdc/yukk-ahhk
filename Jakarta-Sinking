/* ── CALCULATOR (C4) ── */
(function(){
  const sl=document.getElementById('calc-slider');
  if(!sl)return;
  const MAX=2000000,LPH=250,MAXR=12;

  function fmt(n){
    if(n>=1e9)return(n/1e9).toFixed(2)+'B';
    if(n>=1e6)return(n/1e6).toFixed(1)+'M';
    if(n>=1e3)return Math.round(n/1e3)+'K';
    return n.toString();
  }
  function pop(el,val){
    el.classList.remove('ripple');void el.offsetWidth;
    el.textContent=val;el.classList.add('ripple');
  }
  function dots(yrs){
    const el=document.getElementById('calc-dots');
    if(!el)return;el.innerHTML='';
    const max=Math.min(yrs,20);
    for(let i=0;i<max;i++){
      const d=document.createElement('div');
      d.style.cssText=`width:5px;height:5px;border-radius:50%;background:var(--cyan);transition:background 0.3s ${i*0.035}s,transform 0.3s ${i*0.035}s;transform:scale(0)`;
      el.appendChild(d);
      setTimeout(()=>d.style.transform='scale(1)',i*35);
    }
  }
  function update(){
    const hh=+sl.value;
    const pct=(hh-50000)/(MAX-50000);
    const pcti=pct*100;
    sl.style.setProperty('--pct',pcti.toFixed(1)+'%');
    const big=document.getElementById('calc-hh-big');
    if(big) big.textContent=hh>=1e6?(hh/1e6).toFixed(2)+' Juta':Math.round(hh/1000)+' Ribu';
    const gw=hh*LPH;
    pop(document.getElementById('calc-gw'),fmt(gw));
    const sub=(pct*MAXR).toFixed(1);
    pop(document.getElementById('calc-sub'),sub+'cm');
    const sbEl=document.getElementById('calc-sub-bar');
    if(sbEl)sbEl.style.width=Math.min(pct*100,100)+'%';
    const yrs=Math.round(pct*20);
    pop(document.getElementById('calc-years'),'+'+yrs+' thn');
    dots(yrs);
    const dep=Math.min(Math.round((gw/2.6e9)*100),100);
    const g=document.getElementById('gauge-circle');
    if(g){
      const circ=2*Math.PI*55;
      g.style.strokeDashoffset=circ-(dep/100)*circ;
      g.style.strokeDasharray=circ;
    }
    const bp=document.getElementById('calc-pct-big');
    if(bp)bp.textContent=dep+'%';
  }
  sl.addEventListener('input',update);
  setTimeout(update,300);
})();

